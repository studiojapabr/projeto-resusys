#
# INSTRUÇÕES:
# 1. Copie este arquivo e renomeie para ".env" (remova o ".example")
# 2. Acesse seu projeto no Supabase: https://supabase.com/dashboard
# 3. Vá em: Project Settings → API
# 4. Preencha as variáveis abaixo com os valores do seu projeto
#
# ---------------------------------------------------------------
#  VITE (React / Vite)  → use o prefixo VITE_
#  Next.js              → use o prefixo NEXT_PUBLIC_
#  Create React App     → use o prefixo REACT_APP_
# ---------------------------------------------------------------
# Abaixo estão os nomes para VITE. Ajuste o prefixo se necessário.
# ═══════════════════════════════════════════════════════════════

# URL do seu projeto Supabase
# Exemplo: https://xyzxyzxyz.supabase.co
VITE_SUPABASE_URL=https://brylzdwdpreyoltbnwxq.supabase.co

# Chave pública (anon/public) do seu projeto
# NUNCA use a service_role key no frontend!
VITE_SUPABASE_ANON_KEY=sb_publishable_lwcQHW99wZibYnyJtNwXJQ_o2fnpL3M

# ---------------------------------------------------------------
# OPCIONAL: URL base do seu site (usada para redirecionamento
